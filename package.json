{
  "name": "spades-game",
  "private": true,
  "scripts": {
    "dev": "pnpm -r --parallel dev",
    "build": "pnpm -r build",
    "build:prod": "BASE_PATH=${BASE_PATH:-/} pnpm build",
    "start": "pnpm --filter @spades/server start",
    "test": "pnpm -r --filter '!@spades/e2e' test",
    "test:e2e": "pnpm --filter @spades/e2e test",
    "test:all": "pnpm test && pnpm test:e2e",
    "lint": "eslint . && prettier --check .",
    "lint:fix": "eslint . --fix && prettier --write .",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml,html}": [
      "prettier --write"
    ]
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ],
    "overrides": {
      "minimatch@3": "3.1.4",
      "minimatch@10": "10.2.4",
      "socket.io-parser@>=4.0.0 <4.2.6": "4.2.6",
      "flatted@<=3.4.1": "3.4.2",
      "picomatch@>=4.0.0 <4.0.4": "4.0.4",
      "yaml@>=2.0.0 <2.8.3": "2.8.3",
      "brace-expansion@>=5.0.0 <5.0.5": "5.0.5",
      "brace-expansion@>=1.0.0 <1.1.13": "1.1.13",
      "path-to-regexp@>=8.0.0 <8.4.0": "8.4.0"
    }
  },
  "devDependencies": {
    "@eslint/compat": "^2.0.5",
    "@eslint/js": "^10.0.1",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.2"
  },
  "engines": {
    "node": ">=24.0.0"
  }
}
